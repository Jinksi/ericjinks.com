---
import type { CollectionEntry } from 'astro:content'
import { getCollection } from 'astro:content'
import { formatDate } from '../utils/dateUtils'

interface Props {
  posts?: CollectionEntry<'blog'>[]
  showDrafts?: boolean
}

let { posts, showDrafts = false } = Astro.props

if (!posts) {
  posts = (await getCollection('blog')).sort(
    (a, b) =>
      new Date(b.data.pubDate || b.data.updatedDate || '').valueOf() -
      new Date(a.data.pubDate || a.data.updatedDate || '').valueOf()
  )
}

const displayPosts = showDrafts ? posts : posts.filter((post) => !post.data.isDraft)
---

<div class="textContainer">
  <slot />
  {
    displayPosts.map(({ id, data: { title, pubDate, updatedDate, showDate = true, isDraft = false } }) => (
      <a href={`/blog/${id}/`} class="post">
        <span class="title">{title}</span>
        {isDraft && <span class="draft-badge">draft</span>}
        {showDate && (
          <span class="date">
            <time datetime={(updatedDate || pubDate).toDateString()}>
              {formatDate((updatedDate || pubDate || '').toString())}
            </time>
          </span>
        )}
      </a>
    ))
  }
</div>

<style>
  .textContainer {
    padding: 1rem 0;
  }

  .post {
    display: flex;
    align-items: flex-start;
    gap: 1.5rem;
    padding: 0.6rem 0;
    text-decoration: none;
  }

  .title {
    flex: 1;
    line-height: 1.4;
  }

  .post:hover .title {
    text-decoration: underline;
  }

  .date {
    font-weight: 300;
    font-size: 0.85em;
    opacity: 0.5;
    white-space: nowrap;
    flex-shrink: 0;
  }

  .draft-badge {
    font-size: 0.75em;
    opacity: 0.45;
    font-weight: 400;
    flex-shrink: 0;
    padding-top: 0.15em;
  }
</style>
