---
import '@fontsource/fira-code'
import BaseHead from '../components/BaseHead.astro'
import Header from '../components/Nav.astro'
import Footer from '../components/Footer.astro'
import { formatDate } from '../utils/dateUtils'
import { SITE_TITLE } from '../config'
import PostTags from '../components/PostTags.astro'
import type { CollectionEntry } from 'astro:content'
import PostComments from '../components/react/PostComments'

export interface Props {
  post: CollectionEntry<'blog'>
}

const {
  post: {
    data: {
      title,
      description,
      pubDate,
      tags,
      updatedDate,
      showDate = true,
      isDraft,
    },
  },
} = Astro.props
---

<html lang="en">
  <head>
    <BaseHead title={`${title} – ${SITE_TITLE}`} description={description} />
  </head>

  <body>
    <Header />
    <main>
      <article>
        <header class="post-header">
          <div class="container">
            <div class="textContainer auto">
              <div class="post-meta">
                {showDate && !!pubDate && (
                  <time datetime={pubDate.toDateString()}>
                    {formatDate(pubDate.toString())}
                  </time>
                )}
                <PostTags tags={tags} renderAsLinks />
              </div>
              <h1>{title}</h1>
              {isDraft && (
                <p class="draft-notice">
                  <em>⚠️ This is a work in progress...</em>
                </p>
              )}
            </div>
          </div>
        </header>

        <section class="thin">
          <div class="container">
            <div class="textContainer auto">
              <slot />
            </div>
          </div>
        </section>
      </article>

      <section class="thin">
        <div class="container">
          <div class="textContainer auto">
            <PostComments client:only="react" />
          </div>
        </div>
      </section>
    </main>

    <Footer />
    <style>
      .post-header {
        padding: 1rem 0 2rem;
      }

      h1 {
        font-size: 2rem;
        line-height: 1.3;
        font-weight: 700;
        margin: 0.25rem 0 0;
      }

      @media (min-width: 600px) {
        h1 {
          font-size: 2.5rem;
        }
      }

      .post-meta {
        display: flex;
        align-items: center;
        gap: 1rem;
        font-size: 0.85em;
        font-weight: 300;
        opacity: 0.5;
      }

      .post-meta :global(.post-tags) {
        color: inherit;
        font-weight: 300;
      }

      .draft-notice {
        color: var(--color-highlightC);
        font-style: italic;
        font-size: 0.9em;
        margin-top: 0.5rem;
      }
    </style>
  </body>
</html>
